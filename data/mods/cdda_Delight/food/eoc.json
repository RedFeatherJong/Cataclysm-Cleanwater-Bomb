[
  {
    "type": "effect_on_condition",
    "id": "eoc_cd_delight_generic_apply",
    "//": "通用施加/刷新接口。传入 effect_id、intensity、duration、max_intensity、end_var、max_duration。",
    "condition": { "expects_vars": [ "effect_id", "intensity", "duration", "max_intensity", "end_var", "max_duration" ] },
    "effect": [
      { "math": [ "_effective_max_duration = _max_duration > 0 ? _max_duration : _duration" ] },
      {
        "if": { "math": [ "_intensity <= 0" ] },
        "then": [ { "u_lose_effect": [ { "context_val": "effect_id" } ] } ],
        "else": [
          {
            "if": { "u_has_effect": { "context_val": "effect_id" } },
            "then": [
              {
                "if": { "math": [ "_intensity > u_effect_intensity(_effect_id)" ] },
                "then": [
                  { "u_lose_effect": [ { "context_val": "effect_id" } ] },
                  {
                    "u_add_effect": { "context_val": "effect_id" },
                    "intensity": { "math": [ "clamp(_intensity, 1, _max_intensity)" ] },
                    "duration": "PERMANENT"
                  },
                  { "math": [ "v_end_var = time('now') + min(_duration, _effective_max_duration) * time('1 s')" ] }
                ],
                "else": [
                  {
                    "if": { "math": [ "_intensity == u_effect_intensity(_effect_id)" ] },
                    "then": [
                      {
                        "math": [ "v_end_var = min(v_end_var + _duration * time('1 s'), time('now') + _effective_max_duration * time('1 s'))" ]
                      }
                    ]
                  }
                ]
              }
            ],
            "else": [
              {
                "u_add_effect": { "context_val": "effect_id" },
                "intensity": { "math": [ "clamp(_intensity, 1, _max_intensity)" ] },
                "duration": "PERMANENT"
              },
              { "math": [ "v_end_var = time('now') + min(_duration, _effective_max_duration) * time('1 s')" ] }
            ]
          }
        ]
      }
    ]
  },
  {
    "type": "effect_on_condition",
    "id": "eoc_cd_delight_generic_tick",
    "//": "通用到期检查。传入 effect_id、end_var、stacks_var。",
    "condition": { "expects_vars": [ "effect_id", "end_var", "stacks_var" ] },
    "effect": [
      {
        "if": { "math": [ "time('now') >= v_end_var" ] },
        "then": [ { "u_lose_effect": [ { "context_val": "effect_id" } ] }, { "math": [ "v_stacks_var = 0" ] } ]
      }
    ]
  },
