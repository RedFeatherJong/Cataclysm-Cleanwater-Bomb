    "id": "eoc_cd_delight_detoxification_tick",
    "eoc_type": "RECURRING",
    "recurrence": "15 m",
    "//": "每15分钟结算一次：降低 mutant_toxin，强度*15；同时检查是否到期。",
    "condition": { "u_has_effect": "cd_delight_detoxification" },
    "effect": [
